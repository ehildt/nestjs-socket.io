{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "declaration": true,
    "sourceMap": false,
    "removeComments": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "outDir": "./dist",
    "tsBuildInfoFile": "./dist/tsconfig.tsbuildinfo"
  },
  "exclude": [
    "node_modules",
    "test",
    "dist",
    "**/*.spec.ts",
    ".prettierrc.mjs",
    "jest.config.ts",
    "**/*.test.ts",
    "eslint.config.ts",
    "tsup.config.ts",
    "vitest.config.ts"
  ]
}
