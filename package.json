{
  "name": "@ehildt/nestjs-socket.io",
  "description": "A NestJS module for Socket.IO integration with room management and event handling.",
  "version": "0.1.0",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": null,
    "./constants": {
      "types": "./dist/constants/index.d.ts",
      "import": "./dist/constants/index.mjs"
    },
    "./models": {
      "types": "./dist/models/index.d.ts",
      "import": "./dist/models/index.mjs"
    },
    "./module": {
      "types": "./dist/module/index.d.ts",
      "import": "./dist/module/index.mjs"
    },
    "./schema": {
      "types": "./dist/schema/index.d.ts",
      "import": "./dist/schema/index.mjs"
    },
    "./service": {
      "types": "./dist/service/index.d.ts",
      "import": "./dist/service/index.mjs"
    }
  },
  "main": "dist/index.mjs",
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ehildt/nestjs-socket.io.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "author": {
    "email": "eugen.hildt@gmail.com",
    "name": "Eugen Hildt"
  },
  "bugs": {
    "email": "eugen.hildt@gmail.com"
  },
  "scripts": {
    "prepare": "husky",
    "build": "pnpm tsup",
    "depcheck": "npx depcheck .",
    "depcruise": "npx dependency-cruiser -c .depcruise.mjs --ts-config tsconfig.json src",
    "format": "prettier --write .",
    "lint": "eslint ./src",
    "lint:staged": "npx lint-staged --allow-empty",
    "ncu:update": "npx npm-check-updates -u --format group",
    "ncu:interactive": "npx npm-check-updates -u --interactive --format group",
    "ncu:validate": "npx npm-check-updates -e 2 --packageFile=./package.json",
    "prebuild": "rimraf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "lint:unused": "npx ts-unused-exports ./tsconfig.exclude.json --maxIssues=6"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@eslint/js": "^10.0.1",
    "@types/eslint": "^9.6.1",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "4.1.0",
    "depcheck": "^1.4.7",
    "dependency-cruiser": "^17.3.9",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-sonarjs": "^4.0.2",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "jiti": "^2.6.1",
    "lint-staged": "^16.4.0",
    "npm-check-updates": "^19.6.5",
    "rimraf": "^6.1.3",
    "ts-unused-exports": "^11.0.1",
    "tsup": "^8.5.1",
    "typescript-eslint": "^8.57.1",
    "vitest": "^4.1.0"
  },
  "peerDependencies": {
    "@nestjs/common": "^11.1.17",
    "socket.io": "^4.8.1",
    "joi": "^18.0.2"
  }
}
